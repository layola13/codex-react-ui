{
  "name": "codex-react-ui",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "predev": "pnpm --filter @codex-ui/shared build",
    "dev": "concurrently -n server,web -c blue,green \"pnpm --filter @codex-ui/server dev\" \"pnpm --filter @codex-ui/web dev\"",
    "build": "pnpm -r build",
    "launch": "node scripts/launch.mjs",
    "readme:autopush:start": "bash scripts/readme-autopush.sh start",
    "readme:autopush:stop": "bash scripts/readme-autopush.sh stop",
    "readme:autopush:status": "bash scripts/readme-autopush.sh status",
    "readme:autopush:run-once": "bash scripts/readme-autopush.sh run-once",
    "typecheck": "pnpm -r typecheck",
    "test:e2e": "playwright test",
    "start": "pnpm --filter @codex-ui/server start",
    "lint": "pnpm -r lint",
    "check:codex-config-schema": "node scripts/sync-codex-config-schema.mjs",
    "sync:codex-config-schema": "node scripts/sync-codex-config-schema.mjs --write"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3"
  }
}
