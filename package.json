{
  "name": "codex-react-ui",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "predev": "bun --filter @codex-ui/shared build",
    "dev": "bun --filter @codex-ui/web build && bun --filter @codex-ui/server dev",
    "build": "bun --filter @codex-ui/shared build && bun --filter @codex-ui/server build && bun --filter @codex-ui/web build",
    "launch": "bun scripts/launch.mjs",
    "readme:autopush:start": "bash scripts/readme-autopush.sh start",
    "readme:autopush:stop": "bash scripts/readme-autopush.sh stop",
    "readme:autopush:status": "bash scripts/readme-autopush.sh status",
    "readme:autopush:run-once": "bash scripts/readme-autopush.sh run-once",
    "typecheck": "bun --filter @codex-ui/shared --filter @codex-ui/server --filter @codex-ui/web --parallel typecheck",
    "test:e2e": "node ./node_modules/@playwright/test/cli.js test",
    "start": "bun --filter @codex-ui/server start",
    "lint": "bun --filter @codex-ui/shared --filter @codex-ui/server --filter @codex-ui/web --parallel lint",
    "check:codex-config-schema": "bun scripts/sync-codex-config-schema.mjs",
    "sync:codex-config-schema": "bun scripts/sync-codex-config-schema.mjs --write"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/bun": "^1.3.14",
    "typescript": "^5.9.3"
  }
}
