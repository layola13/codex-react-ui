# PostgreSQL
POSTGRES_DB=codex_ui
POSTGRES_USER=codex_ui
POSTGRES_PASSWORD=change-this-postgres-password

# Codex React UI
CODEX_UI_PORT=43110
CODEX_UI_JWT_SECRET=change-this-to-openssl-rand-hex-32
CODEX_UI_ADMIN_EMAIL=admin@example.com
CODEX_UI_ADMIN_PASSWORD=change-this-admin-password
CODEX_UI_JWT_EXPIRE_HOURS=24

# Codex CLI executable inside the application container.
# If the image does not include Codex, mount a host binary in docker-compose.yml
# and set this to the mounted path, for example /usr/local/bin/codex.
CODEX_BIN=codex
